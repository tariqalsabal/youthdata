# رابط ORDS للحسابات — يُستخدم على الخادم فقط (في البروكسي app/api/account)
# لا تستخدم NEXT_PUBLIC هنا حتى لا يُستدعى مباشرة من المتصفح (يسبب حظر CORS).
ORDS_ACCOUNT_BASE=https://youthdata.maxapex.net/ords/data_center/account/v1

# رابط الـ CMS (اختياري)
NEXT_PUBLIC_CMS_API=https://youthdata.maxapex.net/ords/data_center/auth/cms

# اتركه فارغاً ليستخدم الموقع البروكسي الداخلي /api/account (موصى به).
# NEXT_PUBLIC_AUTH_API=

# معرّف Google OAuth (Web application) — يفعّل زر "تسجيل الدخول عبر Google".
# اتركه فارغاً ليختفي الزر حتى تجهّزه. نفس المعرّف يُستخدم في الطرف الخلفي للتحقق.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
